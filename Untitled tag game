-- 1. HITBOX EXPANDER
function expandHitboxes()
    for _, target in pairs(Players:GetPlayers()) do
        if target ~= player and target.Character then
            local root = target.Character:FindFirstChild("HumanoidRootPart")
            local hum = target.Character:FindFirstChild("Humanoid")
            if root and hum and hum.Health > 0 then
                root.Size = state.isExpanded and CONFIG.HitboxSize or Vector3.new(2, 2, 1)
                root.Transparency = state.isExpanded and 0.3 or 1
                root.CanCollide = false
                
                if state.isExpanded and not root:FindFirstChild("HitboxGlow") then
                    local glow = Instance.new("SelectionBox")
                    glow.Name = "HitboxGlow"
                    glow.Adornee = root
                    glow.Color3 = Color3.new(1, 0.2, 0)
                    glow.Transparency = 0.5
                    glow.LineThickness = 0.05
                    glow.Parent = root
                elseif not state.isExpanded and root:FindFirstChild("HitboxGlow") then
                    root.HitboxGlow:Destroy()
                end
            end
        end
    end
end

-- 2. AURA
function createAura()
    clearAura()
    
    if not state.isAuraActive then return end
    
    for i = 1, 20 do
        local angle = (i / 20) * math.pi * 2
        local radius = CONFIG.AuraRadius
        
        local part = Instance.new("Part")
        part.Size = Vector3.new(0.5, 0.5, 0.5)
        part.Shape = Enum.PartType.Ball
        part.BrickColor = BrickColor.new(CONFIG.AuraColor)
        part.Material = Enum.Material.Neon
        part.Anchored = true
        part.CanCollide = false
        part.Transparency = 0.3
        
        local trail = Instance.new("Trail")
        trail.Lifetime = 0.5
        trail.MinLength = 0.5
        trail.Color = ColorSequence.new(CONFIG.AuraColor)
        trail.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)})
        trail.Parent = part
        
        part.Parent = character
        state.auraObjects[#state.auraObjects + 1] = part
        
        RunService.Heartbeat:Connect(function()
            if state.isAuraActive and character and character.Parent then
                local pos = rootPart.Position + Vector3.new(
                    math.cos(angle + tick() * CONFIG.AuraSpeed) * radius,
                    math.sin(tick() * 0.5 + i) * 1.5 + 2,
                    math.sin(angle + tick() * CONFIG.AuraSpeed) * radius
                )
                part.Position = pos
            end
        end)
    end
    
    local ring = Instance.new("Part")
    ring.Size = Vector3.new(CONFIG.AuraRadius * 2, 0.2, CONFIG.AuraRadius * 2)
    ring.Shape = Enum.PartType.Cylinder
    ring.BrickColor = BrickColor.new(CONFIG.AuraColor)
    ring.Material = Enum.Material.Neon
    ring.Anchored = true
    ring.CanCollide = false
    ring.Transparency = 0.6
    ring.Parent = character
    state.auraObjects[#state.auraObjects + 1] = ring
    
    RunService.Heartbeat:Connect(function()
        if state.isAuraActive and character and character.Parent then
            ring.Position = rootPart.Position + Vector3.new(0, 0.1, 0)
            ring.Size = Vector3.new(
                CONFIG.AuraRadius * 2 + math.sin(tick() * 2) * 0.5,
                0.2,
                CONFIG.AuraRadius * 2 + math.sin(tick() * 2) * 0.5
            )
        end
    end)
end

function clearAura()
    for _, obj in pairs(state.auraObjects) do
        if obj and obj.Parent then
            obj:Destroy()
        end
    end
    state.auraObjects = {}
end

-- 3. KILL AURA VISUAL
function createKillAuraVisual()
    clearKillAuraVisual()
    
    local radius = CONFIG.AutoAttackRange
    
    local ring = Instance.new("Part")
    ring.Size = Vector3.new(radius * 2, 0.2, radius * 2)
    ring.Shape = Enum.PartType.Cylinder
    ring.BrickColor = BrickColor.new(Color3.new(1, 0, 0))
    ring.Material = Enum.Material.Neon
    ring.Anchored = true
    ring.CanCollide = false
    ring.Transparency = 0.7
    ring.Parent = character
    state.auraVisuals[#state.auraVisuals + 1] = ring
    
    local innerRing = Instance.new("Part")
    innerRing.Size = Vector3.new(radius * 1.5, 0.2, radius * 1.5)
    innerRing.Shape = Enum.PartType.Cylinder
    innerRing.BrickColor = BrickColor.new(Color3.new(1, 0.3, 0))
    innerRing.Material = Enum.Material.Neon
    innerRing.Anchored = true
    innerRing.CanCollide = false
    innerRing.Transparency = 0.5
    innerRing.Parent = character
    state.auraVisuals[#state.auraVisuals + 1] = innerRing
    
    -- Floating particles
    for i = 1, 12 do
        local angle = (i / 12) * math.pi * 2
        local part = Instance.new("Part")
        part.Size = Vector3.new(0.3, 0.3, 0.3)
        part.Shape = Enum.PartType.Ball
        part.BrickColor = BrickColor.new(Color3.new(1, 0, 0))
        part.Material = Enum.Material.Neon
        part.Anchored = true
        part.CanCollide = false
        part.Transparency = 0.3
        part.Parent = character
        state.auraVisuals[#state.auraVisuals + 1] = part
        
        RunService.Heartbeat:Connect(function()
            if state.isKillAuraActive and character and character.Parent then
                local pos = rootPart.Position + Vector3.new(
                    math.cos(angle + tick() * 1.5) * radius,
                    math.sin(tick() * 2 + i) * 1.5 + 2,
                    math.sin(angle + tick() * 1.5) * radius
                )
                part.Position = pos
            end
        end)
    end
    
    RunService.Heartbeat:Connect(function()
        if state.isKillAuraActive and character and character.Parent then
            local pos = rootPart.Position + Vector3.new(0, 0.1, 0)
            ring.Position = pos
            innerRing.Position = pos + Vector3.new(0, 0.2, 0)
            
            local pulse = 1 + math.sin(tick() * 3) * 0.05
            ring.Size = Vector3.new(radius * 2 * pulse, 0.2, radius * 2 * pulse)
            innerRing.Size = Vector3.new(radius * 1.5 * pulse, 0.2, radius * 1.5 * pulse)
        end
    end)
end

function clearKillAuraVisual()
    for _, obj in pairs(state.auraVisuals) do
        if obj and obj.Parent then
            obj:Destroy()
        end
    end
    state.auraVisuals = {}
end

-- 4. KILL AURA ZONE - TAG TARGET
function killAuraZone()
    if not state.isKillAuraActive then return end
    
    for _, target in pairs(Players:GetPlayers()) do
        if target ~= player and target.Character then
            local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
            local targetHum = target.Character:FindFirstChild("Humanoid")
            
            if targetRoot and targetHum and targetHum.Health > 0 then
                local dist = (rootPart.Position - targetRoot.Position).Magnitude
                
                if dist < CONFIG.AutoAttackRange then
                    tagTarget(target.Character)
                end
            end
        end
    end
end

-- 5. TAG TARGET
function tagTarget(targetChar)
    if not targetChar then return end
    
    local targetPlayer = Players:GetPlayerFromCharacter(targetChar)
    local rotation = CFrame.new(rootPart.Position, targetChar.HumanoidRootPart.Position)
    local x, y, z = rotation:ToEulerAnglesYXZ()
    
    if targetPlayer then
        -- Tag Player
        local bufferData = buffer.create(7)
        buffer.writeu8(bufferData, 0, 1)
        buffer.writeu16(bufferData, 1, math.floor((x + math.pi) / 6.283185307179586 * 65535 + 0.5))
        buffer.writeu16(bufferData, 3, math.floor((y + math.pi) / 6.283185307179586 * 65535 + 0.5))
        buffer.writeu16(bufferData, 5, math.floor((z + math.pi) / 6.283185307179586 * 65535 + 0.5))
        
        local success = TagPlayerEvent:InvokeServer(bufferData)
        
        if success and state.isTagVisualsActive then
            TagHitmarkerEvent:Fire(targetChar, false, 0)
            TagSwingEvent:Fire()
            createTagVisual(targetChar)
        end
    else
        -- Tag Agent/Enemy
        local bufferData = buffer.create(6)
        buffer.writeu16(bufferData, 0, math.floor((x + math.pi) / 6.283185307179586 * 65535 + 0.5))
        buffer.writeu16(bufferData, 2, math.floor((y + math.pi) / 6.283185307179586 * 65535 + 0.5))
        buffer.writeu16(bufferData, 4, math.floor((z + math.pi) / 6.283185307179586 * 65535 + 0.5))
        
        local success = TagAgentEvent:InvokeServer(targetChar, bufferData)
        
        if success and state.isTagVisualsActive then
            TagHitmarkerEvent:Fire(targetChar, false, 0)
            TagSwingEvent:Fire()
            createTagVisual(targetChar)
        end
    end
end

-- 6. TAG VISUAL EFFECT
function createTagVisual(targetChar)
    if not targetChar then return end
    
    local tagPart = Instance.new("Part")
    tagPart.Size = Vector3.new(3, 3, 3)
    tagPart.Shape = Enum.PartType.Ball
    tagPart.BrickColor = BrickColor.new(Color3.new(1, 0.8, 0))
    tagPart.Material = Enum.Material.Neon
    tagPart.Anchored = true
    tagPart.CanCollide = false
    tagPart.Transparency = 0.4
    tagPart.Position = targetChar.HumanoidRootPart.Position + Vector3.new(0, 3, 0)
    tagPart.Parent = Workspace
    
    local tagText = Instance.new("BillboardGui")
    tagText.Name = "TagIndicator"
    tagText.Size = UDim2.new(0, 100, 0, 30)
    tagText.Adornee = targetChar.HumanoidRootPart
    tagText.StudsOffset = Vector3.new(0, 3, 0)
    tagText.Parent = targetChar
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "TAGGED!"
    label.TextColor3 = Color3.new(1, 0.8, 0)
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.Parent = tagText
    
    game:GetService("Debris"):AddItem(tagPart, CONFIG.TagDuration or 3)
    game:GetService("Debris"):AddItem(tagText, CONFIG.TagDuration or 3)
end

