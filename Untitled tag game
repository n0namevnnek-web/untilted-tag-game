-- ===== CORE FUNCTIONS =====

function expandHitboxes()
    for _, target in pairs(Players:GetPlayers()) do
        if target ~= player and target.Character then
            local root = target.Character:FindFirstChild("HumanoidRootPart")
            local hum = target.Character:FindFirstChild("Humanoid")
            if root and hum and hum.Health > 0 then
                root.Size = state.isExpanded and CONFIG.HitboxSize or Vector3.new(2, 2, 1)
                root.Transparency = state.isExpanded and 0.3 or 1
                root.CanCollide = false
                
                if state.isExpanded and not root:FindFirstChild("HitboxGlow") then
                    local glow = Instance.new("SelectionBox")
                    glow.Name = "HitboxGlow"
                    glow.Adornee = root
                    glow.Color3 = Color3.new(1, 0.2, 0)
                    glow.Transparency = 0.5
                    glow.LineThickness = 0.05
                    glow.Parent = root
                elseif not state.isExpanded and root:FindFirstChild("HitboxGlow") then
                    root.HitboxGlow:Destroy()
                end
            end
        end
    end
end

-- ===== EVENT HANDLERS =====

RunService.RenderStepped:Connect(expandHitboxes)

player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    rootPart = character:WaitForChild("HumanoidRootPart")
    
    if state.isSpeedActive then
        humanoid.WalkSpeed = boostedSpeed
    end
end)

